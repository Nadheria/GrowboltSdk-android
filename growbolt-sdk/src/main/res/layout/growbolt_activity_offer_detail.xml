<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/growbolt_bg_screen">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="90dp"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ── Banner image (full width, no toolbar) ─────────────────── -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="220dp">

                <ImageView
                    android:id="@+id/ivBannerDetail"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    />

                <!-- Back button overlaid on banner -->
                <ImageButton
                    android:id="@+id/ibBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_margin="16dp"
                    android:src="@drawable/growbolt_ic_back"
                    android:background="@drawable/growbolt_back_circle"
                    android:contentDescription="Back" />
            </FrameLayout>

            <!-- ── Offer summary card ─────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/growbolt_bg_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:padding="16dp">

                    <!-- Offer logo -->
                    <ImageView
                        android:id="@+id/ivOfferLogo"
                        android:layout_width="64dp"
                        android:layout_height="64dp"
                        android:background="@drawable/growbolt_offer_placeholder"
                        android:scaleType="centerCrop" />

                    <!-- Title + subtitle + hold chip -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView
                            android:id="@+id/tvTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/growbolt_text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Register Now"
                            android:textColor="@color/growbolt_text_secondary"
                            android:textSize="13sp"
                            android:layout_marginTop="2dp" />

                        <!-- Hold period chip -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:background="@drawable/growbolt_hold_chip_bg"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="3dp"
                            android:paddingBottom="3dp"
                            android:layout_marginTop="6dp">

                            <ImageView
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:src="@drawable/growbolt_ic_clock" />

                            <TextView
                                android:id="@+id/tvHoldPeriod"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="@color/growbolt_primary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:layout_marginStart="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Earn label + payout -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Earn"
                            android:textColor="@color/growbolt_text_secondary"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvPayout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/growbolt_primary"
                            android:textSize="20sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Steps card ─────────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:cardBackgroundColor="@color/growbolt_bg_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Steps header row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:id="@+id/tvStepsTitle"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="How to complete"
                            android:textColor="@color/growbolt_text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />

                        <!-- Clock + payout badge row -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/growbolt_ic_clock"
                                android:layout_marginEnd="6dp" />

                            <TextView
                                android:id="@+id/tvPayoutBadge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:background="@drawable/growbolt_payout_btn_bg"
                                android:textColor="@color/growbolt_text_white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:paddingTop="5dp"
                                android:paddingBottom="5dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Steps list container -->
                    <LinearLayout
                        android:id="@+id/layoutSteps"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Warning card ───────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#F9A825"
                app:strokeWidth="1.5dp"
                app:cardBackgroundColor="@color/growbolt_bg_surface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/growbolt_warning_card_bg"
                    android:padding="16dp">

                    <!-- Important Note row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:text="ℹ"
                            android:textColor="#F9A825"
                            android:textSize="14sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Important Note"
                            android:textColor="@color/growbolt_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvImportantNote"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E65100"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        android:layout_marginBottom="12dp"
                        tools:text="You will Not be rewarded if you have installed this app before." />

                    <!-- Warnings row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:text="⚠"
                            android:textColor="#F9A825"
                            android:textSize="14sp"
                            android:gravity="center" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Warnings:"
                            android:textColor="@color/growbolt_text_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginStart="6dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvWarning"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="#E65100"
                        android:textSize="13sp"
                        android:lineSpacingMultiplier="1.4"
                        tools:text="Fake Installs will not be entertained and will lead to deactivation of your account." />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ── Fixed bottom CTA button ───────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/growbolt_bg_surface"
        android:elevation="8dp"
        android:padding="16dp">

        <Button
            android:id="@+id/btnStartOffer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@drawable/growbolt_cta_btn_bg"
            android:textColor="@color/growbolt_text_white"
            android:textSize="17sp"
            android:textStyle="bold"
            android:text="Claim ₹0.00"
            android:stateListAnimator="@null" />
    </LinearLayout>

    <!-- Loading overlay -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:visibility="gone" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
